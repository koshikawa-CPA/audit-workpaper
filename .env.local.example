# Supabase Configuration
# Copy this file to .env.local and fill in your values from https://app.supabase.com

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key for admin operations (keep secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL for invitation email redirect links (e.g. http://localhost:3000 in dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
